# ---- Supabase ----
# Lokal: supabase start → otomatik. Üretim: supabase.com proje URL+anon key.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Email (Resend) ----
RESEND_API_KEY=
EMAIL_FROM="Bridge <bridge@ytublockchain.com>"

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Admin cüzdanları (virgülle) — bu adresler yönetim yetkisi alır
ADMIN_WALLETS=0x0000000000000000000000000000000000000000
